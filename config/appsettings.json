{
  "schemaVersion": "1.0",
  "application": {
    "name": "ProxyAddressManager",
    "startupMode": "GuiShell"
  },
  "gui": {
    "windowTitle": "Proxy Address Manager",
    "windowWidth": 1440,
    "windowHeight": 920
  },
  "paths": {
    "rulesConfiguration": "config/rules.json",
    "defaultExportDirectory": "output",
    "sampleUsersFile": "examples/users.sample.json",
    "sampleRulesFile": "examples/rules.sample.json"
  },
  "bootstrap": {
    "moduleRequirements": [
      {
        "id": "logging",
        "order": 10,
        "displayName": "myPosh Write-Log",
        "moduleNames": [
          "myPosh_write-log",
          "myPosh_Write-Log"
        ],
        "requiredCommands": [
          "Write-Log"
        ],
        "installStrategy": "PSResource",
        "packageName": "myPosh_write-log",
        "repository": "PSGallery",
        "scope": "CurrentUser",
        "requiredAtStartup": true,
        "instructions": "Es gibt keinen Fallback ohne dieses Modul."
      },
      {
        "id": "activeDirectory",
        "order": 20,
        "displayName": "Active Directory PowerShell module",
        "moduleNames": [
          "ActiveDirectory"
        ],
        "requiredCommands": [
          "Get-ADUser"
        ],
        "installStrategy": "Manual",
        "requiredAtStartup": true,
        "instructions": "Bitte installiere die AD PowerShell-Verwaltungstools, z. B. ueber RSAT, bevor die App gestartet wird."
      }
    ]
  }
}
