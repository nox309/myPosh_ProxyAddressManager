<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proxy Address Manager"
        Height="920"
        Width="1440"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FFF4F5F7">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="#FF16324F"
                Padding="20,18,20,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Proxy Address Manager"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Read-only Vorschau fuer regelbasierte SMTP-Adresszuordnung"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="#FFD9E3EC" />
                </StackPanel>

                <Border Grid.Column="1"
                        CornerRadius="14"
                        Background="#334F6D8C"
                        Padding="12,8,12,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Status:"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Name="StatusHeadlineTextBlock"
                                   Margin="8,0,0,0"
                                   Foreground="White"
                                   Text="Bootstrap abgeschlossen" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="#FFE7ECF1"
                   BorderBrush="#FFD4DCE4"
                   BorderThickness="1,1,1,0">
            <StatusBarItem>
                <TextBlock Name="StatusBarTextBlock"
                           Text="Bereit. Das WPF-Grundgeruest ist geladen." />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Margin="0,0,0,18"
                    Padding="16"
                    CornerRadius="16"
                    Background="White"
                    BorderBrush="#FFD7DEE6"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Sitzung"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#FF1A2A38" />
                        <TextBlock Name="SessionSummaryTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#FF4F6174"
                                   Text="Noch keine Benutzer geladen. Die naechsten Inkremente binden Konfiguration und Preview-Engine an." />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Name="LoadUsersButton"
                                Content="Benutzer laden"
                                Width="130"
                                Height="34"
                                Margin="0,0,10,0"
                                IsEnabled="False" />
                        <Button Name="RefreshPreviewButton"
                                Content="Preview aktualisieren"
                                Width="150"
                                Height="34"
                                IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Padding="16"
                    CornerRadius="16"
                    Background="White"
                    BorderBrush="#FFD7DEE6"
                    BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top">
                        <TextBlock Text="Konfiguration"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#FF1A2A38" />
                        <TextBlock Text="App- und Richtlinienstatus"
                                   Margin="0,4,0,14"
                                   Foreground="#FF607284" />
                    </StackPanel>

                    <StackPanel>
                        <Border Background="#FFF5F8FB"
                                BorderBrush="#FFE1E8EF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="App-Root"
                                           FontWeight="SemiBold"
                                           Foreground="#FF26415D" />
                                <TextBlock Name="AppRootTextBlock"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#FF4F6174" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF5F8FB"
                                BorderBrush="#FFE1E8EF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Konfigurationsdatei"
                                           FontWeight="SemiBold"
                                           Foreground="#FF26415D" />
                                <TextBlock Name="ConfigPathTextBlock"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#FF4F6174" />
                            </StackPanel>
                        </Border>

                        <Border Background="#FFF5F8FB"
                                BorderBrush="#FFE1E8EF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12">
                            <StackPanel>
                                <TextBlock Text="Bootstrap-Module"
                                           FontWeight="SemiBold"
                                           Foreground="#FF26415D" />
                                <ItemsControl Name="StartupModulesItemsControl"
                                              Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="16"
                        CornerRadius="16"
                        Background="White"
                        BorderBrush="#FFD7DEE6"
                        BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Benutzerliste"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1A2A38" />
                            <TextBlock Text="Die Liste wird spaeter aus AD oder Testdaten geladen."
                                       Margin="0,4,0,14"
                                       Foreground="#FF607284" />
                        </StackPanel>

                        <DataGrid Name="UsersDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Identity"
                                                    Binding="{Binding Identity}"
                                                    Width="2*" />
                                <DataGridTextColumn Header="OU"
                                                    Binding="{Binding OrganizationalUnit}"
                                                    Width="2*" />
                                <DataGridTextColumn Header="Status"
                                                    Binding="{Binding Status}"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="2"
                        Padding="16"
                        CornerRadius="16"
                        Background="White"
                        BorderBrush="#FFD7DEE6"
                        BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Preview"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF1A2A38" />
                            <TextBlock Text="Ist/Soll-Differenz und Regelzuordnung folgen in den naechsten Inkrementen."
                                       Margin="0,4,0,14"
                                       Foreground="#FF607284" />
                        </StackPanel>

                        <DataGrid Name="PreviewDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Benutzer"
                                                    Binding="{Binding Identity}"
                                                    Width="2*" />
                                <DataGridTextColumn Header="Regel"
                                                    Binding="{Binding AppliedRule}"
                                                    Width="*" />
                                <DataGridTextColumn Header="Aenderung"
                                                    Binding="{Binding ChangeSummary}"
                                                    Width="2*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
